<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0"
      xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.controller.ListDecksController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Stored Decks"/>

    <TableView fx:id="tableView" prefHeight="300.0">
        <columns>
            <TableColumn fx:id="nameColumn" text="Deck Name" prefWidth="200.0"/>
            <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="400.0"/>
        </columns>
    </TableView>

    <HBox spacing="10.0">
        <Button text="Back" onAction="#handleBack"/>
    </HBox>
</VBox>