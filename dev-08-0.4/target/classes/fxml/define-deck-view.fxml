<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0"
      xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.controller.DefineDeckController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Define Deck"/>

    <Label text="Deck Name"/>
    <TextField fx:id="deckNameField" promptText="Enter deck name"/>

    <Label text="Description"/>
    <TextArea fx:id="descriptionArea" promptText="Enter description" prefRowCount="5"/>

    <HBox spacing="10.0">
        <Button text="Save" onAction="#handleSave"/>
        <Button text="Back" onAction="#handleBack"/>
    </HBox>
</VBox>
