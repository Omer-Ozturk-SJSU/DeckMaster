<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.controller.HomeController">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="DeckMaster"/>

    <Button text="Define Deck" onAction="#handleDefineDeck"/>
    <Button text="View Decks" onAction="#handleViewDecks"/>
    <Button text="Define Flashcard" onAction="#handleDefineFlashcard"/>
    <Button text="View Flashcards" onAction="#handleViewFlashcards"/>
    <Button text="Search Flashcards" onAction="#handleSearchFlashcards"/>
</VBox>