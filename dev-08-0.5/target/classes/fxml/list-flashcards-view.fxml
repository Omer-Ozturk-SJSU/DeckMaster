<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.controller.ListFlashcardsController"
      alignment="CENTER"
      spacing="10">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <TableView fx:id="tableView" prefHeight="400.0" prefWidth="850.0">
        <columns>
            <TableColumn fx:id="deckColumn" text="Deck" prefWidth="120.0"/>
            <TableColumn fx:id="frontColumn" text="Front" prefWidth="150.0"/>
            <TableColumn fx:id="backColumn" text="Back" prefWidth="150.0"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100.0"/>
            <TableColumn fx:id="createdAtColumn" text="Created At" prefWidth="150.0"/>
            <TableColumn fx:id="lastReviewAtColumn" text="Last Review" prefWidth="150.0"/>
        </columns>
    </TableView>

    <Button text="Back" onAction="#handleBack"/>
</VBox>