<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0"
      xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cs151.controller.SearchFlashcardController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Search Flashcards"/>

    <HBox spacing="10.0">
        <TextField fx:id="searchField" promptText="Search by deck, front, back, or status"/>
        <Button text="Search" onAction="#handleSearch"/>
        <Button text="Delete Selected" onAction="#handleDelete"/>
        <Button text="Back" onAction="#handleBack"/>
    </HBox>

    <TableView fx:id="tableView" prefHeight="400.0">
        <columns>
            <TableColumn fx:id="deckColumn" text="Deck" prefWidth="140.0"/>
            <TableColumn fx:id="frontColumn" text="Front" prefWidth="180.0"/>
            <TableColumn fx:id="backColumn" text="Back" prefWidth="180.0"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100.0"/>
            <TableColumn fx:id="createdAtColumn" text="Created At" prefWidth="140.0"/>
            <TableColumn fx:id="lastReviewAtColumn" text="Last Review" prefWidth="140.0"/>
        </columns>
    </TableView>

</VBox>